<UserControl
    x:Class="WinKVM.Views.AIChatPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowDefinitions="Auto,*,Auto" Background="{ThemeResource LayerFillColorDefaultBrush}">

        <!-- Header -->
        <StackPanel Grid.Row="0" Padding="12,8" BorderThickness="0,0,0,1"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
            <TextBlock Text="AI Agent" Style="{StaticResource SubtitleTextBlockStyle}"/>
            <ComboBox x:Name="ProviderCombo" HorizontalAlignment="Stretch" Margin="0,4,0,0"
                      SelectionChanged="ProviderCombo_SelectionChanged">
                <ComboBoxItem Content="Claude"/>
                <ComboBoxItem Content="OpenAI"/>
                <ComboBoxItem Content="Grok"/>
                <ComboBoxItem Content="Ollama"/>
            </ComboBox>
        </StackPanel>

        <!-- Message list -->
        <ScrollViewer Grid.Row="1" x:Name="MessageScroll">
            <ListView x:Name="MessageList" Padding="8" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="8" Margin="0,4" CornerRadius="6"
                                Background="{ThemeResource ControlFillColorDefaultBrush}">
                            <StackPanel>
                                <TextBlock Text="{Binding Role}" FontWeight="SemiBold" FontSize="11"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>

        <!-- Input area -->
        <Grid Grid.Row="2" Padding="8" RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
            <!-- Task input -->
            <TextBox x:Name="TaskInput" Grid.Row="0" Header="Task / Message"
                     PlaceholderText="e.g. Open Notepad and type Hello"
                     AcceptsReturn="False" TextWrapping="Wrap"/>

            <!-- Controls -->
            <Grid Grid.Row="1" ColumnDefinitions="*,*,*">
                <Button Grid.Column="0" Content="▶ Run Task" HorizontalAlignment="Stretch"
                        Style="{StaticResource AccentButtonStyle}" Click="RunBtn_Click"/>
                <Button Grid.Column="1" Content="💬 Chat"    HorizontalAlignment="Stretch" Margin="4,0"
                        Click="ChatBtn_Click"/>
                <Button Grid.Column="2" Content="⏹ Stop"    HorizontalAlignment="Stretch"
                        Click="StopBtn_Click"/>
            </Grid>

            <!-- Status -->
            <TextBlock x:Name="AgentStatus" Grid.Row="2" FontSize="11" TextWrapping="Wrap"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
        </Grid>

    </Grid>
</UserControl>
